{
    "name": "controlaltjeff/p7m-fattura-decoder",
    "description": "PHP library per decodificare file PKCS#7 (.p7m) ed estrarre il contenuto XML.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "controlaltjeff@gmail.com",
            "email": "controlaltjeff@gmail.com"
        }
    ],
    "require": {
        "php": ">=5.3",
        "ext-dom": "*",
        "ext-libxml": "*"
    },
    "suggest": {
        "ext-openssl": "Usato come strategia di decodifica primaria (consigliato)"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Controlaltjeff\\P7MDecoder\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Controlaltjeff\\P7MDecoder\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse src --configuration=phpstan.neon",
        "fix": "php-cs-fixer fix --config=.php-cs-fixer.dist.php",
        "fix-dry": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff",
        "mutate": "infection --threads=4 --show-mutations --no-progress",
        "check": ["@test", "@stan", "@fix-dry"]
    },
    "config": {
        "allow-plugins": {
            "infection/extension-installer": true
        }
    }
}
